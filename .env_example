DATABASE_URI=postgresql+asyncpg://postgres:postgres@127.0.0.1/ortdb
TOKEN_URL=http://127.0.0.1:8000/auth/login
LOG_LEVEL=INFO
# Your secret key e.g.  openssl rand -hex 32
SECRET_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
IMAGE_PATH=/tmp
SQL_ECHO=False
# Comma-separated list of allowed CORS origins, e.g. ["https://app.example.com"]
CORS_ORIGINS=[]

# Cache
CACHE_ENABLED=true
# local or redis
CACHE_TYPE=local
CACHE_MAXSIZE=1000
CACHE_TTL=3600

# Redis cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_USERNAME=
